{
    "name": "ordermanagement",
    "version": "1.0.11",
    "private": true,
    "homepage": "https://srthuanan.github.io/ordermanagement",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "electron": "concurrently \"cross-env IS_ELECTRON=true vite\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "tsc && cross-env IS_ELECTRON=true vite build && electron-builder",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d dist",
        "backup": "node backups/run_full_backup.cjs",
        "backup:live": "node backups/realtime_backup.cjs"
    },
    "dependencies": {
        "@google/genai": "^1.22.0",
        "@supabase/supabase-js": "^2.99.2",
        "@types/react-virtualized-auto-sizer": "^1.0.4",
        "@types/react-window": "^1.8.8",
        "axios": "^1.13.6",
        "electron-log": "^5.4.3",
        "electron-updater": "^6.6.2",
        "exceljs": "^4.4.0",
        "framer-motion": "^10.18.0",
        "jspdf": "4.2.1",
        "lucide-react": "^1.8.0",
        "moment": "^2.30.1",
        "pdf-parse": "^2.4.5",
        "pdfjs-dist": "^3.11.174",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-draggable": "^4.5.0",
        "react-markdown": "^10.1.0",
        "react-pdf": "^10.2.0",
        "react-virtualized-auto-sizer": "^2.0.2",
        "react-window": "^2.2.4",
        "remark-gfm": "^4.0.1",
        "sharp": "^0.34.5",
        "supabase": "^2.76.16",
        "swr": "^2.4.1",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/node": "^20.14.9",
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "dotenv": "^17.3.1",
        "electron": "^39.2.6",
        "electron-builder": "^26.0.12",
        "gh-pages": "^6.1.1",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.2.2",
        "vite": "^5.0.8",
        "vite-plugin-compression": "^0.5.1",
        "vite-plugin-pwa": "^1.2.0",
        "wait-on": "^9.0.3"
